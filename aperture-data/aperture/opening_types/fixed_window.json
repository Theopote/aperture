{
  "schemaVersion": 1,
  "id": "aperture:fixed_window",
  "category": "window",
  "parameters": {
    "width": { "type": "length", "default": 1200, "min": 300, "max": 6000 },
    "height": { "type": "length", "default": 1500, "min": 300, "max": 4000 },
    "mullions": { "type": "count", "default": 0, "min": 0, "max": 10 },
    "frame_width": { "type": "length", "default": 50, "min": 20, "max": 150 },
    "frame_depth": { "type": "length", "default": 80, "min": 30, "max": 200 },
    "open_angle": { "type": "angle", "default": 0, "min": 0, "max": 90 }
  },
  "constraints": [
    {
      "expr": "width > height * 0.3",
      "message": "Width must exceed 30% of the height"
    }
  ],
  "generator": "aperture:rectangular_window_v1",
  "components": [
    { "kind": "frame", "id": "frame", "profile": "aperture:frame_l_50x80" },
    { "kind": "glass", "id": "glazing", "system": "aperture:single_glazed" },
    { "kind": "mullion", "id": "mullions", "source": "parameter:mullions" }
  ],
  "materialSlots": ["frame", "glazing"]
}
