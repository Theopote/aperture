{
  "schemaVersion": 1,
  "id": "aperture:door",
  "category": "door",
  "stateSchema": {
    "openRatio": { "type": "number", "default": 0, "min": 0, "max": 1, "persistent": true },
    "locked": { "type": "boolean", "default": false, "persistent": true },
    "enabled": { "type": "boolean", "default": true, "persistent": true },
    "operatingMode": { "type": "enum", "default": "manual", "values": ["manual", "automatic", "redstone", "maintenance"], "persistent": true },
    "durability": { "type": "number", "default": 1, "min": 0, "max": 1, "persistent": true },
    "accessPolicy": { "type": "string", "default": "public", "persistent": true },
    "targetOpenRatio": { "type": "number", "default": 0, "min": 0, "max": 1, "persistent": false },
    "velocity": { "type": "number", "default": 0, "persistent": false },
    "motion": { "type": "enum", "default": "idle", "values": ["idle", "opening", "closing", "blocked"], "persistent": false },
    "activeInteractor": { "type": "string", "default": "", "persistent": false },
    "lastEventTime": { "type": "number", "default": 0, "min": 0, "persistent": false }
  },
  "generator": "aperture:rectangular_window_v1",
  "parameters": {
    "width": {
      "kind": "range",
      "type": "length",
      "label": "Width",
      "group": "Dimensions",
      "default": 1200,
      "min": 600,
      "max": 2400,
      "step": 10
    },
    "height": {
      "kind": "range",
      "type": "length",
      "label": "Height",
      "group": "Dimensions",
      "default": 2300,
      "min": 1800,
      "max": 3000,
      "step": 10
    },
    "thickness": {
      "kind": "range",
      "type": "length",
      "label": "Thickness",
      "group": "Dimensions",
      "default": 60,
      "min": 35,
      "max": 120
    },
    "panel_count": {
      "kind": "range",
      "type": "count",
      "label": "Panel Count",
      "group": "Layout",
      "default": 2,
      "min": 1,
      "max": 6
    },
    "glass_ratio": {
      "kind": "range",
      "type": "number",
      "label": "Glass Ratio",
      "group": "Layout",
      "default": 0.35,
      "min": 0,
      "max": 1,
      "step": 0.05
    },
    "frame_width": {
      "kind": "range",
      "type": "length",
      "label": "Frame Width",
      "group": "Frame",
      "default": 80,
      "min": 40,
      "max": 200
    },
    "hinge_side": {
      "kind": "choice",
      "label": "Hinge Side",
      "default": "left",
      "choices": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    "has_transom": {
      "kind": "boolean",
      "label": "Transom",
      "default": false
    },
    "frame_material": {
      "kind": "material",
      "label": "Frame Material",
      "group": "Materials",
      "default": "minecraft:oak_planks"
    }
  },
  "materialSlots": ["frame", "glazing", "hardware"],
  "components": [
    { "kind": "frame", "id": "door_frame", "profile": "aperture:frame_standard_50" },
    { "kind": "panel", "id": "door_leaf", "profile": "aperture:frame_standard_50", "hinge": "left" },
    { "kind": "glass", "id": "door_glass", "system": "aperture:single_glazed" },
    { "kind": "hardware", "id": "hinges", "type": "hinge_set" },
    { "kind": "handle", "id": "handle" },
    { "kind": "sill", "id": "threshold", "profile": "aperture:frame_standard_50" }
  ]
}
