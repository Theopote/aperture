{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aperture.dev/schemas/opening-instance.schema.json",
  "title": "OpeningInstance",
  "description": "Sparse parameter overrides plus runtime state. Omitted parameters inherit opening type defaults.",
  "type": "object",
  "required": ["schemaVersion", "instanceId", "typeId", "transform", "revision"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "instanceId": {
      "type": "string",
      "format": "uuid"
    },
    "typeId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_/]*$"
    },
    "parameters": {
      "type": "object",
      "description": "Sparse overrides only — keys must match the opening type parametric schema.",
      "additionalProperties": true
    },
    "transform": {
      "type": "object",
      "required": ["x", "y", "z", "facing"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "facing": {
          "type": "string",
          "enum": ["north", "south", "east", "west", "up", "down"]
        }
      }
    },
    "host": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["wall", "roof", "curtain_wall_host", "free_standing"]
        },
        "anchor": { "type": "string" }
      }
    },
    "state": {
      "type": "object",
      "description": "Runtime kinematic state separate from parametric schema.",
      "properties": {
        "openRatio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "0 = closed, 1 = fully open. Scales open_angle when not explicitly overridden."
        }
      }
    },
    "revision": {
      "type": "integer",
      "minimum": 0
    }
  }
}
