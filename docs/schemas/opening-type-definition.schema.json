{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aperture.dev/schemas/opening-type-definition.schema.json",
  "title": "OpeningTypeDefinition",
  "description": "Opening type catalog entry. parameters is the full ParametricSchema (defaults included); instance JSON stores only sparse overrides against this schema.",
  "type": "object",
  "required": ["schemaVersion", "id", "category", "generator", "components"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_/]*$"
    },
    "category": {
      "type": "string",
      "enum": ["door", "window", "curtain_wall", "skylight", "facade"]
    },
    "parameters": {
      "type": "object",
      "description": "Full ParametricSchema keyed by parameter name.",
      "additionalProperties": {
        "$ref": "parameter-schema.schema.json"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["expr", "message"],
        "properties": {
          "expr": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "generator": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_/]*$"
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/componentDefinition"
      }
    },
    "materialSlots": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "componentDefinition": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "frame",
            "panel",
            "glass",
            "mullion",
            "divider",
            "hardware",
            "handle",
            "trim",
            "sill",
            "header",
            "decoration"
          ]
        },
        "id": { "type": "string", "minLength": 1 },
        "profile": { "type": "string" },
        "system": { "type": "string" },
        "hinge": { "type": "string" },
        "type": { "type": "string" },
        "source": {
          "type": "string",
          "description": "Parameter reference, e.g. parameter:cols or parameter:hinge_side"
        },
        "style": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    }
  }
}
